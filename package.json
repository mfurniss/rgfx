  "description": "RGFX - An application and MAME Lua scripts for monitoring emulated game states and publishing network events to control LED hardware",
  "private": true,
  "workspaces": [
    "rgfx-hub"
  ],
  "keywords": [
    "mame",
    "arcade",
    "retro-gaming",
    "mqtt",
    "led",
    "esp32",
    "fastled",
    "game-events",
    "lua"
  ],
  "author": {
    "name": "Matt Furniss",
    "email": "furniss@gmail.com"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/furniss/rgfx.git"
  },
  "homepage": "https://gitlab.com/furniss/rgfx",
  "bugs": {
    "url": "https://gitlab.com/furniss/rgfx/-/issues"
  },
  "scripts": {
    "postinstall": "echo 'RGFX workspace initialized. See README.md for setup instructions.'",
    "esp32:copy-firmware": "cd esp32 && python3 copy_firmware.py"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "vite-plugin-static-copy": "^3.1.4"
  },
