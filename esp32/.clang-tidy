# RGFX ESP32 Driver - clang-tidy Configuration
# Static analysis checks for embedded C++ code

Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-implicit-widening-of-multiplication-result,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity,
  modernize-*,
  -modernize-use-trailing-return-type,
  -modernize-avoid-c-arrays,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-avoid-non-const-global-variables

# Warning as errors for critical issues
WarningsAsErrors: ''

# Header filter - analyze project headers
HeaderFilterRegex: 'src/.*\.h$'

# Check options
CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: camelCase
  - key: readability-identifier-naming.VariableCase
    value: camelCase
  - key: readability-identifier-naming.ParameterCase
    value: camelCase
  - key: readability-identifier-naming.ConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key: readability-braces-around-statements.ShortStatementLines
    value: 1

# Disabled checks explanation:
# - bugprone-easily-swappable-parameters: Too noisy for embedded code with similar types
# - readability-magic-numbers: Common in embedded code (pin numbers, delays, etc.)
# - readability-identifier-length: Short names like 'i', 'x', 'y' are acceptable in tight loops
# - modernize-use-trailing-return-type: Not common in Arduino/ESP32 ecosystem
# - modernize-avoid-c-arrays: C arrays are standard in embedded code
# - cppcoreguidelines-avoid-magic-numbers: Same as readability-magic-numbers
# - cppcoreguidelines-avoid-c-arrays: C arrays are standard in embedded code
# - cppcoreguidelines-pro-bounds-*: Too restrictive for embedded code
# - cppcoreguidelines-avoid-non-const-global-variables: Common pattern in Arduino/ESP32
