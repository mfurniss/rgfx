# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# Python files - PEP 8 standard (4 spaces)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88  # Black formatter default

# Lua files
[*.lua]
indent_style = space
indent_size = 2

# C/C++ files (ESP32)
[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
