{
  "compilerOptions": {
    "jsx": "react",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedSideEffectImports": false,
    "sourceMap": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "types": ["vitest/globals", "node", "w3c-web-serial"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "config/**/*"],
  "exclude": ["node_modules", "dist", ".vite", "out", "vitest.config.ts"]
}
