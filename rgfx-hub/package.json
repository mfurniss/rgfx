{
  "name": "rgfx-hub",
  "productName": "RGFX Hub",
  "version": "1.0.21",
  "description": "Visual effects controller for retro arcade games",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "node scripts/dev-electron.mjs",
    "build": "node scripts/build-electron.mjs",
    "package": "npm run build && electron-builder --dir",
    "make": "npm run build && electron-builder",
    "make:mac": "npm run build && electron-builder --mac",
    "make:win": "npm run build && electron-builder --win",
    "prepackage": "node scripts/generate-icons.js",
    "premake": "node scripts/generate-icons.js",
    "premake:mac": "node scripts/generate-icons.js",
    "premake:win": "node scripts/generate-icons.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm test",
    "unused-exports": "ts-unused-exports tsconfig.json --excludePathsFromReport='config/mappings;src/preload.ts;src/__tests__;src/ipc/contract.ts;vite.renderer.config.ts' --exitWithCount",
    "smoke-test": "python3 ../scripts/e2e-smoke-test.py",
    "smoke-test:verbose": "python3 ../scripts/e2e-smoke-test.py -v",
    "smoke-test:stress": "python3 ../scripts/e2e-smoke-test.py -d 300 --density high -v",
    "generate:defaults": "node scripts/generate-effect-defaults.mjs"
  },
  "keywords": [],
  "author": {
    "name": "Matt Furniss",
    "email": "furniss@gmail.com"
  },
  "license": "MPL-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@stylistic/eslint-plugin": "^2.12.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/ip": "^1.1.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node-ssdp": "^4.0.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/semver": "^7.7.1",
    "@types/w3c-web-serial": "^1.0.8",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "electron": "38.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.18.0",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.3.0",
    "license-checker": "^25.0.1",
    "nodemon": "^3.1.11",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.19.1",
    "vite": "^7.1.12",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/poppins": "^5.2.7",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "aedes": "^0.51.3",
    "chokidar": "^5.0.0",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-window-state": "^5.0.3",
    "framer-motion": "^12.23.25",
    "gifuct-js": "^2.1.2",
    "ip": "^2.0.1",
    "lodash-es": "^4.17.21",
    "node-ssdp": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.67.0",
    "react-router-dom": "^7.9.4",
    "recharts": "^2.15.0",
    "semver": "^7.7.4",
    "tasmota-webserial-esptool": "^9.2.20",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.2.0",
    "zustand": "^5.0.8"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.25.12",
    "@rollup/rollup-darwin-arm64": "^4.53.1",
    "@rollup/rollup-linux-x64-gnu": "^4.53.1"
  }
}
