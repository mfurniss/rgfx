    "publish": "electron-forge publish",
    "prepackage": "node scripts/generate-icons.js",
    "premake": "node scripts/generate-icons.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm test",
    "unused-exports": "ts-unused-exports tsconfig.json --excludePathsFromReport='config/mappings;src/preload.ts;src/__tests__;vite.renderer.config.ts' --exitWithCount"
  },
