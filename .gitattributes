# Auto detect text files and normalise line endings
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.lua text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.bin binary
*.dmg binary
*.zip binary
*.tar.gz binary
*.elf binary
*.hex binary

# Generated site - exclude from diffs and language stats
public-docs/site/** linguist-generated=true
