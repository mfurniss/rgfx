#!/bin/bash
# Pre-commit hook to enforce code quality
# Runs: Hub (TypeScript, ESLint, tests) and ESP32 native tests

set -e  # Exit on any error

ROOT_DIR="$(git rev-parse --show-toplevel)"

echo "🔍 Running pre-commit checks..."

# ===== FIRMWARE BINARY CHECK =====
# Fail if firmware binaries are modified but not staged
FIRMWARE_DIR="rgfx-hub/assets/esp32/firmware"
UNSTAGED_FIRMWARE=$(git diff --name-only -- "$FIRMWARE_DIR" 2>/dev/null || true)

if [ -n "$UNSTAGED_FIRMWARE" ]; then
    echo ""
    echo "❌ ERROR: Firmware binaries modified but not staged!"
    echo "   The following files have unstaged changes:"
    echo "$UNSTAGED_FIRMWARE" | sed 's/^/      /'
    echo ""
    echo "   Run: git add $FIRMWARE_DIR"
    echo "   Or stage specific files before committing."
    exit 1
fi

# ===== RGFX-HUB CHECKS =====
echo ""
echo "📦 Checking rgfx-hub..."
cd "$ROOT_DIR/rgfx-hub"

# 1. TypeScript type checking
echo "📝 TypeScript type checking..."
npm run typecheck
echo "✅ TypeScript checks passed"

# 2. ESLint with auto-fix
echo "🔧 Running ESLint with auto-fix..."
npm run lint -- --fix
echo "✅ ESLint passed"

# 3. Check for unused exports (skip on Windows — known ts-unused-exports bug #302)
if [[ "$(uname -s)" != MINGW* && "$(uname -s)" != MSYS* && "$(uname -s)" != CYGWIN* ]]; then
    echo "🔍 Checking for unused exports..."
    npm run unused-exports
    echo "✅ No unused exports found"
fi

# 4. Run Hub tests
echo "🧪 Running Hub tests..."
npm test
echo "✅ Hub tests passed"

# ===== ESP32 DRIVER CHECKS =====
echo ""
echo "🔌 Checking ESP32 driver..."
cd "$ROOT_DIR/esp32"

# 5. Run native unit tests (fast, no hardware required)
echo "🧪 Running ESP32 native tests..."
pio test -e native
echo "✅ ESP32 native tests passed"

echo ""
echo "✨ All pre-commit checks passed! Proceeding with commit..."
